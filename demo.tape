Output doc/images/melisai_quick_profile.gif
Require ssh

Set FontSize 18
Set Width 1200
Set Height 600
Set Theme "Dracula"
Set WindowBar Colorful

Type "ssh -t -q -o StrictHostKeyChecking=no root@37.27.106.246 'clear; melisai collect --profile quick; sleep 60'"
Enter
# melisai takes about 10-12 seconds
Sleep 13s
